<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to SheCure"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E2E5D"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- SOS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSOS"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:text="🚨 SOS Emergency"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="20dp"
            app:backgroundTint="#D32F2F"/>

        <!-- Safe Route -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSafeRoute"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="Safe Route"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:layout_marginTop="15dp"
            app:cornerRadius="16dp"
            app:backgroundTint="#5E5CE6"
            android:textColor="@android:color/white"/>

        <!-- Profile -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="My Profile"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:layout_marginTop="15dp"
            app:cornerRadius="16dp"
            app:backgroundTint="#5E5CE6"
            android:textColor="@android:color/white"/>


        <!-- News -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNews"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="News"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:layout_marginTop="15dp"
            app:cornerRadius="16dp"
            app:backgroundTint="#34C759"
            android:textColor="@android:color/white"/>

        <!-- Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textAllCaps="false"
            android:layout_marginTop="25dp"
            app:cornerRadius="12dp"
            app:backgroundTint="#8E8E93"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</ScrollView>